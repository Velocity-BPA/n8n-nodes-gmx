{
  "name": "n8n-nodes-gmx",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for GMX decentralized perpetuals exchange providing 23 resources and 200+ operations for perpetual trading, liquidity provision, staking, and DeFi analytics on Arbitrum and Avalanche.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-gmx.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-gmx#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-gmx/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "gmx",
    "perpetuals",
    "defi",
    "arbitrum",
    "avalanche",
    "glp",
    "gm",
    "trading",
    "blockchain",
    "ethereum",
    "derivatives",
    "decentralized-exchange",
    "staking",
    "liquidity"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GmxNetwork.credentials.js",
      "dist/credentials/GmxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Gmx/Gmx.node.js",
      "dist/nodes/Gmx/GmxTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "ethers": "^6.9.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
